# ============================================
# T-Shirt Central 365 - Backend Production Config
# ============================================
# Copy this to .env on your production server and fill in values.

# App
APP_NAME=T-Shirt Central 365
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database (SQLite - no config needed, auto-created)
DATABASE_URL=sqlite+aiosqlite:///tshirtcentral365.db

# JWT Auth
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# Square Payment Processing (PRODUCTION)
# Get from https://developer.squareup.com/apps > Production
SQUARE_APPLICATION_ID=sq0cid-XXXXXXXXXXXXXXXX
SQUARE_ACCESS_TOKEN=EAAAl-XXXXXXXXXXXXXXXX
SQUARE_LOCATION_ID=XXXXXXXXXXXXXXXX
SQUARE_ENVIRONMENT=production
SQUARE_WEBHOOK_SIGNATURE_KEY=XXXXXXXXXXXXXXXX

# Printify Fulfillment
PRINTIFY_API_TOKEN=eyJ0eXAi...
PRINTIFY_SHOP_ID=6906686
PRINTIFY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXX

# Google OAuth
GOOGLE_CLIENT_ID=XXXXXXXXXXXXXXXX.apps.googleusercontent.com

# Wix Integration (optional)
WIX_API_TOKEN=
WIX_ACCOUNT_ID=

# S3 Storage (optional - falls back to local filesystem)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=tshirtcentral365-assets
S3_REGION=us-east-1

# CORS (add your production domains)
CORS_ORIGINS=["https://www.tshirtcentral365.com","https://tshirtcentral365.com"]
