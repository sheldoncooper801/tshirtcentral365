# ============================================
# T-Shirt Central 365 - Frontend Production Config
# ============================================
# Copy this to .env.production on Vercel and fill in values.

# API Backend URL (your deployed backend)
NEXT_PUBLIC_API_URL=https://api.tshirtcentral365.com

# Site URL
NEXT_PUBLIC_SITE_URL=https://www.tshirtcentral365.com

# Google OAuth (from console.cloud.google.com)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Square Payment Processing (PRODUCTION)
NEXT_PUBLIC_SQUARE_APP_ID=sq0cid-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_SQUARE_LOCATION_ID=XXXXXXXXXXXXXXXX

# Wix Analytics (optional)
NEXT_PUBLIC_WIX_TRACKING_ID=
